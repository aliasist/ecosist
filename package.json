{
  "name": "ecosist",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run check:worker",
    "preview": "vite preview",
    "check": "tsc --noEmit && npm run check:worker",
    "check:worker": "tsc --noEmit -p tsconfig.worker.json",
    "cf:dev": "npm run build && npx wrangler dev",
    "cf:deploy": "npm run build && npx wrangler deploy"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.4.5",
    "vite": "^8.0.3"
  }
}
